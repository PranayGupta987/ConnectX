# ConnectX Frontend Environment Variables
# Copy this file to .env and fill in your values

# Base URL of your Express backend (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Socket.io server URL (usually your backend origin, no /api suffix)
VITE_SOCKET_URL=http://localhost:5000

# Public app URL (used for password reset links, OAuth redirects, etc.)
VITE_APP_URL=http://localhost:8080

# Google OAuth (public client id only — never expose the client secret here)
VITE_GOOGLE_CLIENT_ID=

# Cloudinary (unsigned upload preset & cloud name for direct browser uploads, optional)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
